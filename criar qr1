from PIL import Image
from pyzbar.pyzbar import decode as lerqrcode
from qrcode import QRCode as GerarQRCode
import qrcode

def criar_qr():
    produto_a_ser_criado = input("Digite o nome do produto para criar o QR Code: ").upper()
    
    print(f"{produto_a_ser_criado}")
    qr = qrcode.QRCode(version=1, error_correction=qrcode.constants.ERROR_CORRECT_L, box_size=10, border=4)
    qr.add_data(produto_a_ser_criado)
    qr.make(fit=True)

    image = qr.make_image(fill_color="black", back_color="white")
    image.save("qrcode.png")
